# Salesforce Connected App Consumer Key
SALESFORCE_CLIENT_ID=your_connected_app_consumer_key_here

# API-enabled user that the Connected App is authorized for
SALESFORCE_USERNAME=your_sf_username@example.com

# Your org's My Domain URL, e.g. https://yourcompany.my.salesforce.com
SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com

# Use https://login.salesforce.com for production, https://test.salesforce.com for sandbox
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# RSA private key contents with literal \n between lines (NOT actual newlines).
# Generate: openssl genrsa -out private.key 2048
# Escape:   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.key
SALESFORCE_PRIVATE_KEY='-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENTS_HERE\n-----END PRIVATE KEY-----'
